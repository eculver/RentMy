# Backend
PORT=8080
ENV=development
DATABASE_URL=postgres://rentmy:rentmy@localhost:5432/rentmy?sslmode=disable
REDIS_URL=redis://localhost:6380

# S3 (MinIO)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Pusher (Soketi)
PUSHER_APP_ID=app-id
PUSHER_KEY=app-key
PUSHER_SECRET=app-secret
PUSHER_HOST=localhost:6001
PUSHER_CLUSTER=mt1

# JWT
JWT_SECRET=dev-secret-change-in-production

# Stripe (use test mode keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Payment config
TAKE_RATE_BPS=2000
GUARANTEE_RATE_BPS=1000
DAMAGE_RESERVE_RATE_BPS=4000
PAYOUT_DELAY_NEW_HOST_HOURS=48
