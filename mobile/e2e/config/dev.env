APP_ID=com.rentmy.app
API_URL=http://localhost:8080

# Seeded renter account (bob@test.com — no listings, available to book)
RENTER_EMAIL=bob@test.com
RENTER_PASSWORD=password123

# Seeded host account (alice@test.com — owns 5 listings)
HOST_EMAIL=alice@test.com
HOST_PASSWORD=password123

# Simulated GPS location (Los Angeles — matches listing coordinates)
TEST_LATITUDE=34.0522
TEST_LONGITUDE=-118.2437

# Camera bypass: set EXPO_PUBLIC_E2E_MODE=true in the app build to enable
# the AngleEnforcedCamera E2E bypass (see AngleEnforcedCamera.native.tsx).
# Payment bypass: same flag auto-selects e2e_test_card in PaymentMethodSelector.
# Build the app with: EXPO_PUBLIC_E2E_MODE=true npx expo run:ios
E2E_MODE=true

# Backend E2E mode: start backend with E2E_MODE=true to enable the test-only
# booking seed endpoint (POST /api/v1/test/booking) used by booking flows.
# Start with: E2E_MODE=true make dev   (from backend/ directory)
